# ============================================
# LegalLens - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ============================================

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- Database ---
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/legallens
DATABASE_URL=sqlite:///./legal_analyzer.db

# --- Authentication ---
# Generate a strong random key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI (Optional) ---
# Sign up at https://platform.openai.com to get a key.
# This is ONLY needed for LLM-enhanced analysis and Q&A.
# Without it, the app still works using local AI models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
MAX_TEXT_LENGTH=100000

# --- Security ---
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
