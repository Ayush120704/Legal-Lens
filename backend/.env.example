# ============================================
# LegalLens - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
#
# For production deployment (e.g. Render, Railway, Fly):
#   Set ALL of these as environment variables on your hosting platform.
#   The .env file is only for local development.
# ============================================

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- Database ---
# For production, use PostgreSQL (recommended for concurrent users):
#   DATABASE_URL=postgresql://user:pass@host:5432/legallens?sslmode=require
# For local dev, SQLite works fine:
DATABASE_URL=sqlite:///./legal_analyzer.db

# --- Authentication ---
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# In production, set this as a secret env var on your hosting platform.
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI (Optional, for LLM-enhanced analysis) ---
# Sign up at https://platform.openai.com to get a key.
# Without this, the app still works using local AI models (TF-IDF scoring).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
MAX_TEXT_LENGTH=100000

# --- Security ---
# Comma-separated list of allowed CORS origins.
# In production, set this to your frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
# For local development:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
