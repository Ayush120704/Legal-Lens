# Normalize all line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
